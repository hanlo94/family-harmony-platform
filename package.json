{
  "name": "family-harmony-platform",
  "version": "0.1.0",
  "private": true,
  "description": "家庭共享任务与无唠叨协作平台",
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,green \"pnpm dev:backend\" \"pnpm dev:frontend\"",
    "dev:frontend": "cd apps/frontend && pnpm dev",
    "dev:backend": "cd apps/backend && pnpm dev",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:recreate": "docker compose down -v && docker compose up -d",
    "setup": "pnpm install && pnpm db:up && pnpm db:migrate && pnpm db:seed",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:e2e": "playwright test",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:reset": "prisma migrate reset",
    "db:studio": "prisma studio",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.vue": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.scss": [
      "prettier --write"
    ],
    "*.{json,md,yaml}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@parcel/watcher",
      "@prisma/client",
      "@prisma/engines",
      "core-js",
      "esbuild",
      "prisma",
      "vue-demi"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.60.0",
    "concurrently": "^10.0.3",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "playwright": "^1.60.0",
    "prettier": "^3.8.4",
    "prisma": "5.22.0",
    "typescript-eslint": "^8.61.0"
  },
  "dependencies": {
    "@prisma/client": "5.22.0"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}
