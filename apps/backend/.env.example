# ═══ 数据库 ═══
# PostgreSQL 连接字符串（Prisma 使用）
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/family_harmony_dev?schema=public"

# ═══ 服务端口 ═══
PORT=3001

# ═══ JWT ═══
# 生产环境务必替换为安全的随机密钥
JWT_SECRET="change-me-to-a-secure-random-string"
JWT_REFRESH_SECRET="change-me-to-another-secure-random-string"

# ═══ 微信 ═══
# 微信公众号 AppID 和 AppSecret（用于 OAuth 登录和模板消息）
WECHAT_APP_ID="your-wechat-app-id"
WECHAT_APP_SECRET="your-wechat-app-secret"

# ═══ 文件上传 ═══
UPLOAD_DIR="./uploads"
UPLOAD_MAX_SIZE=5242880
